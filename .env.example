APP_NAME=JustQiuV2 Rewrite
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_LOCALE=en
APP_TIMEZONE=Asia/Jakarta

HTTP_PORT=8080

DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=justqiuv2_rewrite
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_SECRET=change-me-session-secret-32chars
CSRF_SECRET=change-me-csrf-secret-32chars!!!
CSRF_TRUSTED_ORIGINS=localhost:5173,127.0.0.1:5173,localhost:4173,127.0.0.1:4173
TOKEN_DISPLAY_ENCRYPTION_KEY=change-me-token-key-32chars!!!

QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=justqiuv2-rewrite

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1

QRIS_BASE_URL=
QRIS_CLIENT=
QRIS_CLIENT_KEY=
QRIS_GLOBAL_UUID=

NEXUSGGR_BASE_URL=
NEXUSGGR_AGENT_CODE=
NEXUSGGR_AGENT_TOKEN=

QUEUE_WORKER_CONCURRENCY=10
PROMETHEUS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=
